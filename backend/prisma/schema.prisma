generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String               @id @default(uuid())
  email        String               @unique
  passwordHash String
  name         String
  role         Role
  verified     Boolean              @default(false)
  verification VerificationRequest?
  avatar       String?
  location     String?
  createdAt    DateTime             @default(now())

  campaigns Campaign[]  @relation("UserCampaigns")
  donations Donation[]
  bloodbank BloodBank[]

  // blood donation bridge relations
  donationsMade     BloodDonation[] @relation("DonorDonations")
  donationsReceived BloodDonation[] @relation("OrgDonations")

  bloodRequest BloodRequest[] @relation("orgBloodReq")
  fulfilledRequests BloodRequest[] @relation("FulfillingOrg")
  pledges      Pledge[]
  
  inventoryLogs InventoryLog[]
  inventoryItems InventoryItem[] @relation("OrgInventory")

  sosAlerts        SOSAlert[]
  disasterReports  DisasterReport[] @relation("ReportedDisasters")
  resolvedReports  DisasterReport[] @relation("ResolvedDisasters")

  tutorProfile     TutorProfile?
  enrolledSessions SessionEnrollment[]
  tutoringLogs     TutoringLog[]
}

model VerificationRequest {
  id         String             @id @default(uuid())
  userId     String             @unique
  user       User               @relation(fields: [userId], references: [id])
  docUrl     String
  status     VerificationStatus @default(PENDING)
  createdAt  DateTime           @default(now())
  reviewedAt DateTime?
}

model Campaign {
  id          String        @id @default(uuid())
  title       String
  description String
  organizer   String // email of the org
  type        RequestType
  target      Int
  raised      Int           @default(0)
  unit        String
  status      RequestStatus @default(PENDING)
  deadline    String?
  image       String?
  location    String?
  urgent      Boolean       @default(false)
  category    String?
  details     Json?
  createdBy   String
  createdAt   DateTime      @default(now())
  user        User?         @relation(fields: [createdBy], references: [id], name: "UserCampaigns")
  donations   Donation[]
}

model Donation {
  id         String         @id @default(uuid())
  campaignId String
  campaign   Campaign       @relation(fields: [campaignId], references: [id])
  donorId    String
  donor      User           @relation(fields: [donorId], references: [id])
  donorName  String
  amount     Int
  type       DonationType
  status     DonationStatus @default(COMPLETED)
  items      String? // JSON or comma-separated for MATERIAL
  createdAt  DateTime       @default(now())
}

model BloodBank {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  bloodType String
  units     Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, bloodType])
}

model BloodDonation {
  id             String   @id @default(uuid())
  donorId        String
  organizationId String
  bloodType      String
  units          Int
  donatedAt      DateTime @default(now())
  hasPleadged    Boolean  @default(false)

  donor        User @relation("DonorDonations", fields: [donorId], references: [id])
  organization User @relation("OrgDonations", fields: [organizationId], references: [id])

  @@index([donorId])
  @@index([organizationId])
}

model BloodRequest {
  id             String             @id @default(uuid())
  organizationId String
  bloodType      String
  units          Int
  hospitalName   String
  patientName    String
  contactNo      String
  status         BloodRequestStatus @default(PENDING)
  fulfilledUnits Int                @default(0)

  createdAt DateTime @default(now())

  organization User @relation("orgBloodReq", fields: [organizationId], references: [id])

  pledges       Pledge[]
  
  // Fulfillment Details
  fulfilledBy   String? // Organization ID
  fullfiller    User?   @relation("FulfillingOrg", fields: [fulfilledBy], references: [id])
  fulfilledDate DateTime?
}

model Pledge {
  id        String   @id @default(uuid())
  requestId String
  request   BloodRequest @relation(fields: [requestId], references: [id])
  
  donorId   String
  donor     User     @relation(fields: [donorId], references: [id])
  
  // Form Details
  name      String
  address   String
  contact   String
  units     Int
  
  status    PledgeStatus @default(PENDING)
  createdAt DateTime @default(now())
}

enum PledgeStatus {
  PENDING
  FULFILLED
  CANCELLED
}

enum BloodRequestStatus {
  FULFILLED
  PENDING
}

enum DonationType {
  MONEY
  MATERIAL
  VOLUNTEER
  BLOOD
}

enum DonationStatus {
  PROCESSING
  COMPLETED
}

enum Role {
  INDIVIDUAL
  ORGANIZATION
  ADMIN
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum RequestType {
  MONETARY
  MATERIAL
  VOLUNTEER
  BLOOD
  DISASTER
  EDUCATION
  HEALTH
  WELFARE
}

enum RequestStatus {
  PENDING
  VERIFIED
  FULFILLED
  URGENT
  REJECTED
}

model InventoryLog {
  id             String   @id @default(uuid())
  organizationId String
  action         String   // "ADD", "EDIT", "FULFILL", "PLEDGE_FULFILL"
  bloodType      String
  units          Int      // Quantity changed or final quantity? Let's say Quantity Changed for now, or just log the action details
  description    String?  // "Added 10 units", "Fulfilled request #123"
  createdAt      DateTime @default(now())

  organization   User     @relation(fields: [organizationId], references: [id])
}

model SOSAlert {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  lat       Float
  lng       Float
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}

model DisasterReport {
  id          String   @id @default(uuid())
  reporterId  String
  reporter    User     @relation("ReportedDisasters", fields: [reporterId], references: [id])
  type        String
  description String
  status      ReportStatus @default(PENDING)
  lat         Float?
  lng         Float?
  createdAt   DateTime @default(now())

  resolvedById String?
  resolvedBy   User?    @relation("ResolvedDisasters", fields: [resolvedById], references: [id])
}

enum ReportStatus {
  PENDING
  VERIFIED
  RESOLVED
}

model TutorProfile {
  id        String   @id @default(uuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id])
  bio       String?
  subjects  String
  mode      String
  address   String?
  rating    Float    @default(0.0)
  reviews   Int      @default(0)
  verified  Boolean  @default(false)
  createdAt DateTime @default(now())

  sessions  TutoringSession[]
}

model TutoringSession {
  id          String   @id @default(uuid())
  tutorId     String
  tutor       TutorProfile @relation(fields: [tutorId], references: [id])
  subject     String
  date        String
  time        String
  mode        String
  address     String?
  meetingLink String?
  maxStudents Int
  status      String   @default("OPEN") // OPEN, FULL
  createdAt   DateTime @default(now())

  enrollments SessionEnrollment[]
  logs        TutoringLog[]
}

model SessionEnrollment {
  id        String   @id @default(uuid())
  sessionId String
  session   TutoringSession @relation(fields: [sessionId], references: [id])
  studentId String
  student   User     @relation(fields: [studentId], references: [id])
  joinedAt  DateTime @default(now())
  
  @@unique([sessionId, studentId])
}

model TutoringLog {
  id          String   @id @default(uuid())
  sessionId   String?
  session     TutoringSession? @relation(fields: [sessionId], references: [id])
  userId      String?
  user        User?    @relation(fields: [userId], references: [id])
  action      String   // "SESSION_CREATED", "STUDENT_ENROLLED"
  details     String?  // Optional extra details
  createdAt   DateTime @default(now())
}

model InventoryItem {
  id             String   @id @default(uuid())
  organizationId String
  organization   User     @relation("OrgInventory", fields: [organizationId], references: [id])
  category       String   // "BLOOD", "MONEY", "CLOTHES", "FOOD", "MEDICINE", "OTHER"
  name           String   // e.g., "Funds", "Winter Blankets"
  quantity       Float
  unit           String   // "INR", "Pieces", "Kg", "Units"
  details        Json?
  createdAt      DateTime @default(now())
  lastUpdated    DateTime @updatedAt

  @@unique([organizationId, category, name])
}
